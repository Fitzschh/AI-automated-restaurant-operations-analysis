# ─── Backend-only (FastAPI) — NOT exposed to browser ─────────────────────────
# REQUIRED: OpenAI API key for AI analysis
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini

# REQUIRED if Firebase Auth verification is enabled:
GOOGLE_CLOUD_PROJECT=your_firebase_project_id

# OPTIONAL: Firebase Realtime Database for AI usage tracking
FIREBASE_DATABASE_URL=https://your-project-default-rtdb.firebasedatabase.app

# OPTIONAL: Path to Firebase service account JSON for full token verification
# FIREBASE_SERVICE_ACCOUNT=./service-account.json

# ─── UiPath Maestro Integration (Backend only) ───────────────────────────────
UIPATH_CLOUD_URL=https://cloud.uipath.com
UIPATH_ACCOUNT_NAME=your_account_name
UIPATH_TENANT_NAME=your_tenant_name
UIPATH_CLIENT_ID=your_oauth_client_id
UIPATH_CLIENT_SECRET=your_oauth_client_secret
UIPATH_PROCESS_RELEASE_KEY=your_process_release_key
UIPATH_FOLDER_ID=your_orchestrator_folder_id

# ─── Frontend (Vite) — exposed to browser ────────────────────────────────────
VITE_FIREBASE_API_KEY=your_firebase_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_firebase_auth_domain_here
VITE_FIREBASE_DATABASE_URL=your_firebase_database_url_here
VITE_FIREBASE_PROJECT_ID=your_firebase_project_id_here
VITE_FIREBASE_STORAGE_BUCKET=your_firebase_storage_bucket_here
VITE_FIREBASE_MESSAGING_SENDER_ID=your_firebase_messaging_sender_id_here
VITE_FIREBASE_APP_ID=your_firebase_app_id_here
VITE_RECAPTCHA_SITE_KEY=your_recaptcha_site_key_here

VITE_EVENT_GATEWAY_URL=http://localhost:8080
